{
    "version": 2,
    "framework": null,
    "buildCommand": "",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        },
        "api/test.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        { "src": "/phptest", "dest": "/api/test.php" },
        {
            "src": "/(.+\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp|map))",
            "dest": "/$1"
        },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
